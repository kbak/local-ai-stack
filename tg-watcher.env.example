# Telegram user account credentials
# Get api_id and api_hash from https://my.telegram.org → "API development tools"
TG_API_ID=12345678
TG_API_HASH=your_api_hash_here

# Only needed for the first interactive login — can be removed once session file is saved
TG_PHONE=+1234567890

# Group to monitor — numeric ID (e.g. -1001234567890) or @username
# To find the numeric ID: forward any message from the group to @userinfobot on Telegram
TG_GROUP=-1001234567890

# Summary schedule (UTC) — default is 12:00 UTC = 5:00 AM MST
SUMMARY_CRON_HOUR=12
SUMMARY_CRON_MINUTE=0

# How many hours back to include in the brief (default: 24)
SUMMARY_LOOKBACK_HOURS=24

# LLM — inherits from .env if not set here
# INFERENCE_BASE_URL=http://host.docker.internal:8080/v1
# INFERENCE_API_KEY=sk-no-key-required
# INFERENCE_MODEL=qwen
