# LLM - points to llama-swap on host
LLM_BASE_URL=http://host.docker.internal:8080/v1
LLM_API_KEY=sk-no-key-required
LLM_MODEL=qwen
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Signal API - internal Docker service
SIGNAL_API_URL=http://signal-api:8080

# Your Signal phone number (international format)
SIGNAL_NUMBER=+1234567890
# ALLOWED_NUMBERS=+14155551234,+14155559999

# Recipient for all briefings (calendar-watcher, tg-watcher, etc.)
BRIEFING_RECIPIENT=+1234567890

# Whisper voice transcription (STT)
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Kokoro TTS — voice note replies (sent after text reply to voice messages)
# Voices: af_heart, af_bella, am_adam, am_michael, bf_emma, bm_george
# Lang codes: a=en-US, b=en-GB
TTS_ENABLED=true
TTS_VOICE=af_heart
TTS_LANG=a
TTS_SPEED=1.0

# Group behavior
BOT_GROUP_PREFIX=@006

# GitHub API (read-only, no scopes needed for public repos)
GITHUB_TOKEN=your-token-here

# Music download skill
# Set MUSIC_HOST_DIR in your shell or .env for docker-compose volume substitution:
#   MUSIC_HOST_DIR=D:/backup/Music  (maps to /music inside the container)
# Comma-separated list of subdir:GenreTag pairs
MUSIC_DIRS=rock:Rock,top40:Top 40
# Classification rules fed to the LLM (semicolon-separated)
MUSIC_CLASSIFY_PROMPT="rock -> rock; everything else -> top40"
# URL of the host yt-dlp service (runs outside Docker)
YTDLP_SERVICE_URL=http://host.docker.internal:8200
