# Whisper (STT)
WHISPER_MODEL=distil-large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# Kokoro (TTS) — single source of truth for stack-wide voice/lang/speed defaults.
# Callers (voice-agent, watchers, etc.) omit these fields so the values here
# apply. Change DEFAULT_VOICE here and `docker compose restart audio-api` to
# swap voices stack-wide.
ONNX_PROVIDER=CUDAExecutionProvider
DEFAULT_VOICE=bm_george
DEFAULT_LANG=b
DEFAULT_SPEED=1.0
