# RSS feeds grouped by category (JSON object: category → list of feed URLs)
# signal-bot.env already provides: LLM_BASE_URL, LLM_API_KEY, LLM_MODEL,
#   SIGNAL_API_URL, SIGNAL_NUMBER, BRIEFING_RECIPIENT — no need to repeat them here
RSS_FEEDS={"technology": ["https://feeds.arstechnica.com/arstechnica/index", "https://www.theverge.com/rss/index.xml"], "general": ["https://feeds.bbci.co.uk/news/rss.xml"], "cars": ["https://www.motortrend.com/feeds/all/"]}

# How many hours back to scan per run — default matches the twice-daily cadence
# RSS_LOOKBACK_HOURS=12
