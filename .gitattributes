# Default: treat as text, normalize to LF in the repo, check out as-is on disk.
* text=auto eol=lf

# Shell scripts MUST be LF — bash breaks on CRLF in shebangs/heredocs.
*.sh    text eol=lf
*.bash  text eol=lf

# Source / config — keep LF everywhere so WSL and Windows agree.
*.py        text eol=lf
*.js        text eol=lf
*.ts        text eol=lf
*.jsx       text eol=lf
*.tsx       text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.ini       text eol=lf
*.cfg       text eol=lf
*.conf      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.env       text eol=lf
*.example   text eol=lf
*.jinja     text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.sql       text eol=lf
*.xml       text eol=lf

Dockerfile      text eol=lf
*.Dockerfile   text eol=lf
.dockerignore  text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf
.editorconfig  text eol=lf

# Windows-only artifacts — leave them CRLF if they ever show up.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binaries — never touch.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.tgz   binary
*.7z    binary
*.mp3   binary
*.wav   binary
*.flac  binary
*.mp4   binary
*.mov   binary
*.bin   binary
*.gguf  binary
*.safetensors binary
*.pt    binary
*.pth   binary
*.onnx  binary
