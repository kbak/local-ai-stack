# Discord user token (Settings → Advanced → copy token from network tab)
DISCORD_TOKEN=

# Discord channel ID (right-click channel → Copy Channel ID, needs Developer Mode on)
DISCORD_CHANNEL_ID=

# GitHub repo to monitor in owner/repo format
GITHUB_REPO=

# Summary schedule (default: Monday 08:00 UTC)
SUMMARY_CRON_DAY=mon
SUMMARY_CRON_HOUR=8
SUMMARY_CRON_MINUTE=0
