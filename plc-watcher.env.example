# Merkuriusz Rzeczypospolitej — daily news from the lands of the
# Polish–Lithuanian Commonwealth (1650 borders), in old-styled Polish.
# signal-bot.env already provides: LLM_BASE_URL, LLM_API_KEY, LLM_MODEL,
#   SIGNAL_API_URL, SIGNAL_NUMBER, BRIEFING_RECIPIENT — no need to repeat them here.

# RSS feeds grouped by modern country (JSON object: country → list of feed URLs)
PLC_FEEDS={"Korona (Polska)": ["https://www.rp.pl/rss_main", "https://www.bankier.pl/rss/wiadomosci.xml"], "Wielkie Księstwo Litewskie": ["https://www.lrt.lt/pl/wiadomosci?rss"], "Białoruś": ["https://news.zerkalo.io/rss/all.rss"], "Ziemie Ruskie (Ukraina)": ["https://www.ukrinform.pl/rss/block-lastnews", "https://www.pravda.com.ua/rss/"], "Inflanty (Łotwa)": ["https://eng.lsm.lv/rss/"]}

# Recipient: phone number or group.<id>. Unset → falls back to BRIEFING_RECIPIENT.
# PLC_RECIPIENT=group.XXXX

# How many hours back to scan per run — default matches the daily cadence
# PLC_LOOKBACK_HOURS=24

# Chatterbox voice-sample stem for the Polish voice note (empty = default voice)
# PLC_VOICE=
