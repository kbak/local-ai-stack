# Poll cadence
POLL_INTERVAL_MINUTES=5

# Dry-run mode — log what would happen without touching Sheets or archiving.
# Set to "false" only after you've verified extraction quality.
DRY_RUN=true

# IMAP account passwords — reference by name from accounts.yaml (password_env)
# WORK_IMAP_PASSWORD=replace_me
# FASTMAIL_APP_PASSWORD=replace_me
