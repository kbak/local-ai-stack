MONGO_URI=mongodb://mongodb:27017/LibreChat
DOMAIN_CLIENT=http://localhost:3080
DOMAIN_SERVER=http://localhost:3080
JWT_SECRET=change_me_to_a_random_64_char_hex_string
JWT_REFRESH_SECRET=change_me_to_a_different_random_64_char_hex_string
ALLOW_REGISTRATION=true
MCP_ALLOWED_DOMAINS=http://mcp-proxy:8083
MCP_PROXY_AUTH_TOKEN=change_me_to_a_random_secret

# GitHub MCP (read-only token, scopes: public_repo or repo for private)
GITHUB_TOKEN=your-token-here

# CalDAV (shared by mcp-proxy caldav tool, location-tracker, and meal-watcher)
CALDAV_BASE_URL=https://your-nextcloud.example.com/remote.php/dav
CALDAV_USERNAME=your-username
CALDAV_PASSWORD=your-app-password

# Location Tracker + Meal Watcher (shared)
HOME_CITY=Your City
CALDAV_CALENDAR_NAMES=Travel        # comma-separated calendar names; empty = all calendars
POLL_INTERVAL_MINUTES=5
LOOKBACK_DAYS=30
LOOKAHEAD_DAYS=90

# Google places api key
GOOGLE_MAPS_API_KEY=api_key

# Long-term memory (mem0 + Qdrant).
# MEMORY_DIR is an absolute path on the host where SOUL.md, USER.md,
# MEMORY.md, and Qdrant's vector storage live. Keep this outside the repo
# so it isn't accidentally committed.
MEMORY_DIR=/absolute/path/to/your/memory
# Identifier for the default memory scope. Single-user setups can leave this
# as-is; multi-user deployments should pass user_id explicitly from the client.
MEMORY_DEFAULT_USER_ID=default

# Which GPU hosts the "secondary" always-resident workloads: audio-api
# (whisper + kokoro) and the small always-on llama-swap models (coder +
# fallback chat). The primary GPU is left free for the swappable main chat
# model. Value goes into CUDA_VISIBLE_DEVICES for each of those processes.
# Accepts either an index ("0", "1", ...) or a stable UUID ("GPU-xxxx...")
# from `nvidia-smi -L`. Defaults to "0" (first GPU) so single-GPU clones
# just work. On multi-GPU hosts, pick the smaller/less-loaded card.
SECONDARY_GPU=0

# Host directory containing reference .wav files for Chatterbox voice cloning.
# Mounted read-only into audio-api at /app/voice-samples and read-write into
# signal-bot at /app/voice-samples (so /sample can write new samples).
# Filename stem (e.g. "joe" for joe.wav) is what gets passed as the `voice`
# arg to clone_voice.
VOICE_SAMPLES_DIR=/absolute/path/to/your/voice-samples

# Host directory containing music files served by signal-bot's music skill.
# Mounted read-write into signal-bot at /music.
MUSIC_HOST_DIR=/absolute/path/to/your/music

# Host directory for the on-demand image-gen service (SwarmUI + Flux).
# Bind-mounted into the container as the SwarmUI Models root, so e.g.
# ${IMAGE_DIR}/unet/flux1-dev-fp8.safetensors becomes
# /opt/swarmui/Models/unet/flux1-dev-fp8.safetensors at runtime.
# Keep outside the repo — model weights are large (~30 GB) and not under
# version control.
IMAGE_DIR=/absolute/path/to/your/images

# Host directory where image-gen writes generated images. Bind-mounted into
# the SwarmUI container at /opt/swarmui/Output, so PNGs land directly on the
# host filesystem (browsable, easy to back up). Keep outside the repo.
IMAGE_OUTPUT_DIR=/absolute/path/to/your/image-output

# Which GPU hosts the on-demand image-gen service. Mirrors SECONDARY_GPU
# semantics: accepts an index ("0", "1", ...) or a stable UUID
# ("GPU-xxxx...") from `nvidia-smi -L`. Should point at the LARGER card —
# image-gen is sporadic and the main LLM is unloaded before launch, so
# the primary GPU is the right home. Defaults to "0".
PRIMARY_GPU=0
